# ============================================================
# Seats-pdo-intl — Apache Configuration
# ============================================================

# --- Directory Protection ---
Options -Indexes
DirectoryIndex index.php

# --- Block access to sensitive files ---
<FilesMatch "\.(sql|md|txt|ods|json|lock)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Block dotfiles (.git, .env, etc.)
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# --- Block direct access to includes and vendor ---
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to includes/ directory
    RewriteRule ^includes/ - [F,L]

    # Block direct access to vendor/ directory
    RewriteRule ^vendor/ - [F,L]

    # Block direct access to Docs/ directory
    RewriteRule ^Docs/ - [F,L]
</IfModule>

# --- Force HTTPS in production ---
# Skip when accessed over localhost / 127.0.0.1 / RFC1918 so local dev (e.g.
# the bundled php -S server) still works.
<IfModule mod_rewrite.c>
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1|10\..*|192\.168\..*|172\.(1[6-9]|2[0-9]|3[0-1])\..*)(:\d+)?$
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# --- Security Headers (supplement PHP headers) ---
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

    # HSTS: tell browsers to use HTTPS for the next year. Only sent on HTTPS
    # responses so HTTP -> HTTPS redirects above are not bypassed.
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" "expr=%{HTTPS} == 'on'"

    # Content Security Policy. The codebase uses inline <script> blocks and
    # inline event handlers (footer language switch, index.php seat handlers,
    # admin settings page), so 'unsafe-inline' is required for script-src and
    # style-src today. Tighten once those are externalized.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"

    # Remove server signature
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# --- Disable server signature ---
ServerSignature Off

# --- PHP Settings (if allowed) ---
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag expose_php Off
    php_value session.cookie_httponly 1
    php_value session.cookie_samesite Strict
    php_value session.use_strict_mode 1
</IfModule>

# --- Compression ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json
</IfModule>

# --- Browser Caching ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

# --- UTF-8 ---
AddDefaultCharset UTF-8
